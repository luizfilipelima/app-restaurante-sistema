# Chave de autenticação da Evolution API (obrigatório)
# Use uma chave forte e única - será gerada automaticamente pelo install.sh
AUTHENTICATION_API_KEY=change-me

# Senha do PostgreSQL (será gerada automaticamente pelo install.sh)
POSTGRES_PASSWORD=change-me

# Banco de dados
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:POSTGRES_PASSWORD_PLACEHOLDER@postgres:5432/evolution?schema=public
DATABASE_CONNECTION_CLIENT_NAME=evolution
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true

# URL pública da API (obrigatório para QR/WebSocket no Manager remoto)
SERVER_URL=https://api.quiero.food

# WebSocket — necessário para o Manager exibir o QR code
WEBSOCKET_ENABLED=true

# Versão do cliente WhatsApp — atualize se o QR não aparecer
# Obter em: WhatsApp Web → Configurações → Ajuda (ex: 2.3000.1023923395)
CONFIG_SESSION_PHONE_VERSION=2.3000.1023923395

# Redis
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://redis:6379
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_LOCAL_ENABLED=false
